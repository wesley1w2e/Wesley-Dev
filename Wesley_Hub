          <div style="margin-top:12px;display:flex;gap:8px">
            <button id="minimizeBtn" class="wbtn" title="Minimizar">_</button>
            <button id="maximizeBtn" class="wbtn" title="Compact">▢</button>
            <button id="closeBtn" class="wbtn" title="Fechar">✕</button>
          </div>
        </div>
      </aside>

      <!-- CENTER -->
      <main class="content">
        <div class="topbar panel">
          <div>
            <div class="clock" id="clock">--:--</div>
            <div class="muted" id="date">-- -- ----</div>
          </div>
          <div style="display:flex;gap:12px;align-items:center">
            <div class="muted" id="motivational">"Codifique. Crie. Cresça."</div>
            <div style="display:flex;gap:8px;align-items:center">
              <button id="soundToggle" class="wbtn" title="Som">🔈</button>
              <div style="width:12px"></div>
            </div>
          </div>
        </div>

        <section id="views" style="min-height:0">
          <!-- Dashboard -->
          <div id="dashboard" class="panel fade-in">
            <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
              <div>
                <div style="font-size:20px;font-weight:800">Painel</div>
                <div class="muted">Visão geral rápida</div>
              </div>
              <div style="display:flex;gap:8px;align-items:center">
                <button id="newNoteQuick" class="btn">+ Nota Rápida</button>
              </div>
            </div>

            <div style="margin-top:12px;display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div class="panel">
                <div class="muted">Tempo Hoje</div>
                <div id="todayTime" style="font-weight:800;font-size:18px">0h 0m</div>
              </div>
              <div class="panel">
                <div class="muted">Nível</div>
                <div id="level" style="font-weight:800;font-size:18px">Nível 1</div>
              </div>
            </div>
          </div>

          <!-- NOTES -->
          <div id="notas" class="panel" style="display:none">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
              <div><h3 style="margin:0">Bloco de Notas</h3><div class="muted">Crie, edite, proteja</div></div>
              <div style="display:flex;gap:8px">
                <button id="createNote" class="btn">+ Nova Nota</button>
                <select id="filterCategory"><option value="">Todas</option></select>
              </div>
            </div>
