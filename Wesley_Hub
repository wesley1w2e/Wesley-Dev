      <div id="splashTitle" class="splash-title">WESLEY DEV</div>
      <div id="splashSub" class="splash-sub">HUB • COMMAND CENTER</div>
      <div class="splash-progress" id="splashProgress"><i></i></div>
    </div>
  </div>

  <!-- APP SHELL (hidden until splash finishes) -->
  <div id="appShell" style="display:none;">
    <div class="shell" id="shell">
