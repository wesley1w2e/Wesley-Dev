                <div id="pomTimer" style="font-size:32px;font-weight:900">25:00</div>
                <div style="display:flex;gap:8px;justify-content:center;margin-top:8px">
                  <button id="pomStart" class="btn">Start</button>
                  <button id="pomStop" class="btn">Stop</button>
                  <button id="pomSkip" class="btn">Skip</button>
                </div>
              </div>
            </div>
          </div>

          <div id="ferramentas" class="panel" style="display:none">
            <h3>Ferramentas</h3>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
              <div class="panel">
                <h4>Calculadora</h4>
                <input id="calcExpr" placeholder="Ex: (12+3)/3" />
                <div style="margin-top:8px"><button id="calcRun" class="btn">Calcular</button><div id="calcResult" class="muted" style="margin-top:8px"></div></div>
              </div>
              <div class="panel">
                <h4>Gerador de Senhas</h4>
                <input id="passLength" type="number" min="6" max="64" value="16" style="width:80px"/>
                <div style="margin-top:8px"><button id="genPass" class="btn">Gerar</button><div id="passResult" class="muted" style="margin-top:8px;word-break:break-all"></div></div>
              </div>
