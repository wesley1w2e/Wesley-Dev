          </div>

          <div id="config" class="panel" style="display:none">
            <h3>Configurações</h3>
            <div style="display:flex;flex-direction:column;gap:8px">
              <div style="display:flex;gap:8px;align-items:center">
                <label>Auto-lock (min)</label>
                <input id="autoLockMins" type="number" min="1" max="60" value="5" style="width:80px"/>
              </div>
              <div style="display:flex;gap:8px;align-items:center">
                <label>Proteção por senha</label>
                <button id="setPassword" class="btn">Criar/Alterar</button>
