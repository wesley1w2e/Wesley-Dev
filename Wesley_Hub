              </section>
            </div>
          </div>

          <!-- IDEAS -->
          <div id="ideias" class="panel" style="display:none">
            <h3>Banco de Ideias</h3>
            <div style="display:flex;gap:8px;margin-top:8px">
              <input id="ideaText" placeholder="Ideia..." style="flex:1"/>
              <select id="ideaType">
                <option value="video">Vídeo</option><option value="live">Live</option><option value="prog">Programação</option><option value="proj">Projeto</option><option value="study">Estudo</option><option value="church">Igreja</option>
              </select>
              <input id="ideaTags" placeholder="tags (vídeo,js)" style="width:160px"/>
              <button id="addIdea" class="btn">Salvar</button>
            </div>
            <div id="ideasList" style="margin-top:12px;max-height:420px;overflow:auto"></div>
          </div>

          <!-- CREATOR, PROGRAMMING, STUDIES, PRODUCTIVITY, TOOLS, CONFIG (kept similar) -->
          <div id="criador" class="panel" style="display:none">
            <h3>Criador de Conteúdo</h3>
            <textarea id="planVideo" placeholder="Planejamento..." style="width:100%;min-height:120px"></textarea>
            <div style="margin-top:8px"><button id="savePlan" class="btn">Salvar Plano</button></div>
          </div>

          <div id="programacao" class="panel" style="display:none">
            <h3>Programação</h3>
            <div style="display:flex;gap:8px">
              <div style="flex:1">
                <h4>Projetos</h4>
                <div id="projectsList"></div>
                <div style="margin-top:8px"><input id="newProjectName" placeholder="Nome do projeto"/><button id="addProject" class="btn">Adicionar</button></div>
              </div>
              <div style="width:320px">
