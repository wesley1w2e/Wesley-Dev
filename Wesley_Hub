      </main>

      <!-- RIGHT -->
      <aside class="rightcol" style="display:flex;flex-direction:column;gap:12px">
        <div class="panel">
          <h4>Conquistas & XP</h4>
          <div id="achievementsList" style="display:flex;gap:8px;flex-wrap:wrap"></div>
        </div>
        <div class="panel">
          <h4>Atalhos</h4>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button id="openNotes" class="btn">Notas</button>
            <button id="openIdeas" class="btn">Ideias</button>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- tray icon -->
  <div id="trayIcon" class="tray-icon" style="display:none">W</div>

  <!-- overlay login -->
  <div id="overlay" class="overlay" style="display:none">
    <div class="login panel">
      <div style="display:flex;gap:12px;align-items:center;justify-content:center"><div class="logo-mini">W</div><h2 style="margin:0">WESLEY DEV HUB</h2></div>
      <p class="muted" id="loginMsg">Insira sua senha</p>
      <div class="field" style="margin-top:12px">
        <input id="passwordInput" type="password" placeholder="Senha" />
      </div>
      <div style="display:flex;gap:10px;justify-content:center;margin-top:12px">
        <button id="loginBtn" class="btn">Entrar</button>
        <button id="setupBtn" class="btn" style="display:none">Criar Senha</button>
      </div>
      <div style="margin-top:12px;display:flex;gap:8px;justify-content:center">
        <button id="resetProtected" class="btn" style="background:linear-gradient(90deg,var(--danger), #ff9b9b);color:white">Resetar Proteção</button>
      </div>
      <div class="muted" style="margin-top:10px;font-size:13px">Se esquecer a senha, os dados protegidos não podem ser recuperados.</div>
    </div>
  </div>

  <!-- toast -->
  <div id="toast" class="toast" style="display:none;position:fixed;right:18px;bottom:18px;background:rgba(0,0,0,0.6);padding:12px 16px;border-radius:10px;border:1px solid rgba(255,255,255,0.03);color:var(--text);z-index:250"></div>
</div>

<script>
/* ==================================================================================
   WESLEY DEV HUB — Single-file improved (HTML/CSS/JS)
   - Fixed splash/open sequencing bug
   - Improved intro + UI polish
   - All event bindings happen after init
   - Password protection (WebCrypto) retained
   ================================================================================== */

(() => {
  // Helpers
  const $ = (s, ctx=document) => ctx.querySelector(s);
  const $$ = (s, ctx=document) => Array.from((ctx||document).querySelectorAll(s));
  const toast = (txt, t=3000) => {
    const el = $('#toast');
    el.textContent = txt; el.style.display='block';
    clearTimeout(el._t); el._t = setTimeout(()=> el.style.display='none', t);
  };

  // Storage keys
  const KEY_SETTINGS = 'wdh_settings_v2';
  const KEY_PROTECTED = 'wdh_protected_v2';
  const KEY_DATA = 'wdh_data_v2';

  // Defaults
  const defaultData = { notes:[], ideas:[], tasks:[], projects:[], issues:[], plans:{}, xp:0, achievements:[], meta:{created:new Date().toISOString()} };
  let SETTINGS = JSON.parse(localStorage.getItem(KEY_SETTINGS) || JSON.stringify({ autoLockMins:5, sound:true }));

  // State
  let APP = null;
  let LOCKED = false;
  let derivedKey = null;
  let lastActivity = Date.now();
  let AUTOLOCK_MS = (SETTINGS.autoLockMins||5)*60*1000;

  // CRYPTO helpers (PBKDF2 + AES-GCM)
  const enc = new TextEncoder(), dec = new TextDecoder();
  const bufToB64 = (b) => btoa(String.fromCharCode(...new Uint8Array(b)));
  const b64ToBuf = (s) => Uint8Array.from(atob(s), c=>c.charCodeAt(0));

  async function deriveKeyFromPassword(password, salt, iterations=200000){
    const pwKey = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']);
    return crypto.subtle.deriveKey({name:'PBKDF2', salt, iterations, hash:'SHA-256'}, pwKey, {name:'AES-GCM', length:256}, false, ['encrypt','decrypt']);
  }
  async function createPassword(password){
    const salt = crypto.getRandomValues(new Uint8Array(16));
    const key = await deriveKeyFromPassword(password, salt);
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const cipher = await crypto.subtle.encrypt({name:'AES-GCM', iv}, key, enc.encode('wesley-hub-verifier-v2'));
    const protector = { salt: bufToB64(salt), iv: bufToB64(iv), cipher: bufToB64(cipher) };
    localStorage.setItem(KEY_PROTECTED, JSON.stringify(protector));
    derivedKey = key;
    toast('Senha criada. Proteção ativada.');
    return true;
  }
  async function verifyPassword(password){
    const prot = JSON.parse(localStorage.getItem(KEY_PROTECTED) || 'null');
    if(!prot) return false;
    try {
      const salt = b64ToBuf(prot.salt), iv = b64ToBuf(prot.iv), cipher = b64ToBuf(prot.cipher);
      const key = await deriveKeyFromPassword(password, salt);
      const plain = await crypto.subtle.decrypt({name:'AES-GCM', iv}, key, cipher);
      const txt = dec.decode(plain);
      if(txt === 'wesley-hub-verifier-v2'){ derivedKey = key; return true; }
      return false;
    } catch(e){ return false; }
  }
  async function encryptDataWithKey(key, obj){
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const cipher = await crypto.subtle.encrypt({name:'AES-GCM', iv}, key, enc.encode(JSON.stringify(obj)));
    return { iv: bufToB64(iv), cipher: bufToB64(cipher) };
  }
  async function decryptDataWithKey(key, blob){
    const iv = b64ToBuf(blob.iv), cipher = b64ToBuf(blob.cipher);
    const plain = await crypto.subtle.decrypt({name:'AES-GCM', iv}, key, cipher);
    return JSON.parse(dec.decode(plain));
  }

  async function loadAppData(){
    const raw = localStorage.getItem(KEY_DATA);
    if(!raw) { return JSON.parse(JSON.stringify(defaultData)); }
    try {
      const parsed = JSON.parse(raw);
      if(parsed.encrypted){
        if(!derivedKey) throw new Error('locked');
        return await decryptDataWithKey(derivedKey, parsed.blob);
      } else return parsed.blob;
    } catch(e){
      console.warn('loadAppData error', e);
      return JSON.parse(JSON.stringify(defaultData));
    }
  }
  async function saveAppData(obj){
    try {
      if(localStorage.getItem(KEY_PROTECTED) && derivedKey){
        const blob = await encryptDataWithKey(derivedKey, obj);
        localStorage.setItem(KEY_DATA, JSON.stringify({ encrypted:true, blob }));
      } else {
        localStorage.setItem(KEY_DATA, JSON.stringify({ encrypted:false, blob:obj }));
      }
    } catch(e){
      console.error('saveAppData error', e);
    }
  }
  function resetProtection(){
    if(!confirm('Resetar proteção e deletar dados protegidos?')) return;
    localStorage.removeItem(KEY_PROTECTED);
    localStorage.removeItem(KEY_DATA);
    derivedKey = null;
    toast('Proteção resetada. Reiniciando...');
    setTimeout(()=> location.reload(), 900);
  }

  // Auto-lock
  function resetInactivity(){ lastActivity = Date.now(); }
  function startAutoLockTimer(){
    AUTOLOCK_MS = (SETTINGS.autoLockMins||5)*60*1000;
    clearInterval(window._lockChk);
    window._lockChk = setInterval(()=> {
      if(Date.now() - lastActivity > AUTOLOCK_MS && !LOCKED){
        doLock();
      }
    }, 2000);
  }

  // UI controls
  function showOverlay(msg='Insira sua senha', showSetup=false){
    $('#overlay').style.display='flex';
    $('#loginMsg').textContent = msg;
    $('#passwordInput').value = '';
    $('#setupBtn').style.display = showSetup ? 'inline-block' : 'none';
    $('#loginBtn').style.display = showSetup ? 'none' : 'inline-block';
    $('#passwordInput').focus();
  }
  function hideOverlay(){ $('#overlay').style.display='none'; }
  async function doLock(){
    LOCKED = true; derivedKey = null;
    showOverlay('Sessão bloqueada. Insira a senha.');
    toast('Aplicativo bloqueado');
  }
  async function doUnlock(password){
    if(!localStorage.getItem(KEY_PROTECTED)){
      LOCKED = false; hideOverlay(); return true;
    }
    const ok = await verifyPassword(password);
    if(ok){ LOCKED = false; hideOverlay(); APP = await loadAppData(); renderAll(); toast('Desbloqueado'); return true; }
    toast('Senha incorreta'); return false;
  }

  // Splash — particles + cinematic animation + audio optional
  function startSplashThenInit(){
    const splash = $('#splash'), canvas = $('#splashCanvas'), ctx = canvas.getContext('2d'), logo = $('#logoCard'), title = $('#splashTitle'), sub = $('#splashSub'), prog = $('#splashProgress'), progBar = prog.querySelector('i');
    let w = canvas.width = window.innerWidth, h = canvas.height = window.innerHeight;
    window.addEventListener('resize', ()=>{ w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; });

    // Create particles (subtle, professional)
    const P = [];
    for(let i=0;i<90;i++){
      P.push({ x: Math.random()*w, y: Math.random()*h, r: 0.6 + Math.random()*2.2, vx: (Math.random()-0.5)*0.45, vy: (Math.random()-0.5)*0.45, alpha: 0.12 + Math.random()*0.6 });
    }
    let last = performance.now();
    function draw(t){
      const dt = (t-last)/1000; last=t;
      ctx.clearRect(0,0,w,h);
      // subtle background glow radial
      const g = ctx.createRadialGradient(w*0.7, h*0.2, 0, w*0.7, h*0.2, Math.max(w,h));
      g.addColorStop(0, 'rgba(0,186,255,0.02)'); g.addColorStop(1,'rgba(0,0,0,0)');
      ctx.fillStyle = g; ctx.fillRect(0,0,w,h);
      for(const p of P){
        p.x += p.vx * (1 + Math.sin(t/7000)*0.6);
        p.y += p.vy * (1 + Math.cos(t/6000)*0.6);
        if(p.x < -10) p.x = w+10; if(p.x > w+10) p.x = -10;
        if(p.y < -10) p.y = h+10; if(p.y > h+10) p.y = -10;
        ctx.beginPath();
        ctx.fillStyle = `rgba(44,212,255,${p.alpha})`;
        ctx.shadowBlur = 18; ctx.shadowColor = '#00baff';
        ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
      }
      requestAnimationFrame(draw);
    }
    requestAnimationFrame(draw);

    // cinematic sequence with Promise chaining
    const delay = (ms)=> new Promise(r=>setTimeout(r,ms));
    (async ()=>{
      // small entrance
      await delay(300);
      logo.style.transition = 'transform .9s cubic-bezier(.2,.9,.2,1), opacity .9s'; logo.style.transform = 'scale(1)'; logo.style.opacity = 1;
      // reveal title
      await delay(320);
      title.style.transition = 'opacity .7s .1s, transform .7s .1s'; title.style.opacity = 1; title.style.transform = 'translateY(0)';
      await delay(140);
      sub.style.transition = 'opacity .6s .2s, transform .6s .2s'; sub.style.opacity = 1; sub.style.transform = 'translateY(0)';
      // progress animate (simulate loading modules)
      prog.style.opacity = 1;
      for(let p=0;p<=100;p+=1){
        progBar.style.width = p + '%';
        if(p===10) await delay(80);
        if(p===40) await delay(180);
        if(p===75) await delay(90);
        await delay(12);
      }
      // optional startup sound via WebAudio
      if(SETTINGS.sound){
        try{
          const ctxAudio = new (window.AudioContext || window.webkitAudioContext)();
          const o = ctxAudio.createOscillator(), g = ctxAudio.createGain();
          o.type = 'sine'; o.frequency.value = 520;
          g.gain.value = 0.0001;
          o.connect(g); g.connect(ctxAudio.destination);
          o.start();
          g.gain.exponentialRampToValueAtTime(0.08, ctxAudio.currentTime + 0.02);
          g.gain.exponentialRampToValueAtTime(0.00001, ctxAudio.currentTime + 0.5);
          o.stop(ctxAudio.currentTime + 0.6);
        }catch(e){ console.warn('audio start failed', e); }
      }
      // fade out splash and init app
      splash.style.opacity = 0; await delay(700); splash.style.display='none';
      // show app shell now
      $('#appShell').style.display = 'block';
      // fade-in shell
      const shell = $('#shell'); shell.style.opacity = 0; shell.style.transition = 'opacity .6s ease, transform .6s ease'; shell.style.transform = 'translateY(8px)';
      requestAnimationFrame(()=>{ shell.style.opacity = 1; shell.style.transform = 'translateY(0)'; });
      // Initialize app data and bind events
      await initApp();
    })();
  }

  // Application core: load data, render, bind
  async function initApp(){
    startAutoLockTimer();
    APP = await loadAppData();
    renderAll();
    // if protected & no key, show overlay for unlock
    if(localStorage.getItem(KEY_PROTECTED) && !derivedKey){
      LOCKED = true; showOverlay('Insira sua senha para desbloquear', false);
    } else { LOCKED = false; hideOverlay(); }
    bindEvents(); // bind all events now that UI exists
    // realtime clock
    setInterval(()=> { const d=new Date(); $('#clock').textContent = d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}); $('#date').textContent = d.toLocaleDateString(); }, 1000);
  }

  /* ===========================
     Rendering helpers (notes, ideas, projects, tasks, achievements)
     =========================== */
  function renderAll(){
    renderNotes(); renderIdeas(); renderProjects(); renderTasks(); renderAchievements();
    $('#xpBadge').textContent = 'XP: ' + (APP.xp||0);
    $('#level').textContent = 'Nível ' + (1 + Math.floor((APP.xp||0)/100));
    $('#todayTime').textContent = '0h 0m';
  }
  function escapeHtml(s=''){ return s.replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

  // Notes
  function renderNotes(){
    const cats = [...new Set((APP.notes||[]).map(n=>n.category).filter(Boolean))];
    $('#filterCategory').innerHTML = '<option value="">Todas</option>' + cats.map(c=>`<option>${escapeHtml(c)}</option>`).join('');
    const q = ($('#noteSearch')?.value || '').toLowerCase();
    const list = $('#notesList'); list.innerHTML = '';
    const items = (APP.notes || []).filter(n => !q || (n.title||'').toLowerCase().includes(q) || (n.content||'').toLowerCase().includes(q));
    items.sort((a,b)=> b.updatedAt.localeCompare(a.updatedAt)).forEach(n=>{
      const el = document.createElement('div'); el.className='note-item panel';
      el.innerHTML = `<div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <div style="font-weight:800">${escapeHtml(n.title||'Sem título')}</div>
          <div class="muted" style="font-size:12px">${n.category || ''} • ${new Date(n.updatedAt).toLocaleString()}</div>
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn small" data-id="${n.id}" data-act="open">Abrir</button>
        </div>
      </div>`;
      list.appendChild(el);
    });
    clearEditor();
  }
  function clearEditor(){ $('#noteTitle').value=''; $('#noteContent').value=''; $('#noteCategory').value=''; $('#noteMeta').textContent=''; $('#favNote').checked=false; delete $('#deleteNote').dataset.id; delete $('#saveNote').dataset.id; }
  function openNoteById(id){
    const n = (APP.notes||[]).find(x=>x.id===id); if(!n) return;
    $('#noteTitle').value = n.title; $('#noteContent').value = n.content; $('#noteCategory').value = n.category || ''; $('#noteMeta').textContent = 'Criado: ' + new Date(n.createdAt).toLocaleString() + ' • Editado: ' + new Date(n.updatedAt).toLocaleString(); $('#favNote').checked = !!n.favorite; $('#saveNote').dataset.id = n.id; $('#deleteNote').dataset.id = n.id;
  }
  function createNote(){
    const now = new Date().toISOString();
    const note = { id:'n'+Date.now(), title:'Nova nota', content:'', favorite:false, category:'', createdAt:now, updatedAt:now };
    APP.notes.unshift(note); saveAppData(APP); renderAll(); openNoteById(note.id);
  }
  function saveNoteFromEditor(){
    const id = $('#saveNote').dataset.id;
    const title = $('#noteTitle').value.trim(); const content = $('#noteContent').value; const category = $('#noteCategory').value.trim(); const fav = $('#favNote').checked;
    if(id){
      const n = APP.notes.find(x=>x.id===id); if(n){ n.title=title; n.content=content; n.category=category; n.favorite=fav; n.updatedAt = new Date().toISOString(); }
    } else {
      const now = new Date().toISOString();
      const note = { id:'n'+Date.now(), title, content, favorite:fav, category, createdAt:now, updatedAt:now };
      APP.notes.unshift(note); $('#saveNote').dataset.id = note.id;
    }
    saveAppData(APP); renderAll(); toast('Nota salva');
  }
  function deleteNoteById(id){
    if(!id) return; if(!confirm('Excluir nota?')) return;
    APP.notes = (APP.notes||[]).filter(n=>n.id!==id); saveAppData(APP); renderAll(); clearEditor(); toast('Nota excluída');
  }

  // Ideas
  function renderIdeas(){ const list = $('#ideasList'); list.innerHTML=''; for(const it of (APP.ideas||[]).slice().reverse()){ const el = document.createElement('div'); el.className='panel'; el.style.marginBottom='8px'; el.innerHTML = `<div style="font-weight:800">${escapeHtml(it.text)}</div><div class="muted">${it.type} • ${it.tags||''} • ${new Date(it.createdAt).toLocaleString()}</div>`; list.appendChild(el); } }
  function addIdea(){ const text = $('#ideaText').value.trim(); if(!text) return; APP.ideas.push({ id:'i'+Date.now(), text, type:$('#ideaType').value, tags:$('#ideaTags').value, createdAt:new Date().toISOString() }); saveAppData(APP); renderIdeas(); $('#ideaText').value=''; toast('Ideia salva'); }

  // Projects
  function renderProjects(){ const p = $('#projectsList'); p.innerHTML=''; for(const pr of (APP.projects||[])){ const el = document.createElement('div'); el.className='muted'; el.style.marginBottom='6px'; el.innerHTML = `<div style="display:flex;justify-content:space-between"><div><strong>${escapeHtml(pr.name)}</strong><div class="muted">${pr.desc||''}</div></div><div><button class="btn small" data-act="openProj" data-id="${pr.id}">Abrir</button></div></div>`; p.appendChild(el); } }
  function addProject(){ const name = $('#newProjectName').value.trim(); if(!name) return; APP.projects.push({ id:'p'+Date.now(), name, desc:'' }); saveAppData(APP); $('#newProjectName').value=''; renderProjects(); toast('Projeto criado'); }

  // Tasks
  function renderTasks(){ const tlist = $('#tasksList'); tlist.innerHTML=''; for(const t of (APP.tasks||[]).slice().reverse()){ const el = document.createElement('div'); el.style.display='flex'; el.style.justifyContent='space-between'; el.style.alignItems='center'; el.style.marginBottom='6px'; el.innerHTML = `<div><input type="checkbox" data-id="${t.id}" ${t.done?'checked':''}/> <strong>${escapeHtml(t.text)}</strong> <span class="muted" style="font-size:12px">${t.due?('• '+t.due):''}</span></div><div><button class="btn small" data-act="rm" data-id="${t.id}">X</button></div>`; tlist.appendChild(el); } }
  function addTask(){ const txt = $('#taskText').value.trim(); if(!txt) return; APP.tasks.push({ id:'t'+Date.now(), text:txt, done:false, createdAt:new Date().toISOString() }); $('#taskText').value=''; saveAppData(APP); renderTasks(); }

  // Achievements & XP
  function grantXP(amount){ APP.xp = (APP.xp||0) + (amount||0); saveAppData(APP); renderAchievements(); $('#xpBadge').textContent = 'XP: ' + APP.xp; }
  function renderAchievements(){ const el = $('#achievementsList'); el.innerHTML=''; const list = (APP.achievements||[]); if(list.length===0) el.innerHTML = '<div class="muted">Nenhuma conquista ainda.</div>'; for(const a of list){ const d = document.createElement('div'); d.className='pill'; d.style.padding='6px 10px'; d.style.borderRadius='999px'; d.style.background='rgba(255,255,255,0.02)'; d.textContent = a.title; el.appendChild(d); } }

  // Tools
  function runCalc(){ const ex = $('#calcExpr').value.trim(); if(!ex) return; try{ const val = Function('"use strict"; return ('+ex+')')(); $('#calcResult').textContent = String(val); }catch(e){ $('#calcResult').textContent = 'Erro'; } }
  function genPassword(len){ len = Math.max(6, Math.min(128, parseInt(len)||16)); const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()-_=+[]{};:,.<>?'; let out=''; for(let i=0;i<len;i++) out += chars[Math.floor(Math.random()*chars.length)]; $('#passResult').textContent = out; }

  // Window simulation
  function minimizeApp(){ $('#appShell').style.display='none'; $('#trayIcon').style.display='flex'; toast('Minimizado'); }
  function restoreApp(){ $('#appShell').style.display='block'; $('#trayIcon').style.display='none'; toast('Restaurado'); }

  // Pomodoro
  let pomInterval=null, pomSeconds=1500, pomRunning=false;
  function updatePomDisplay(){ $('#pomTimer').textContent = String(Math.floor(pomSeconds/60)).padStart(2,'0') + ':' + String(pomSeconds%60).padStart(2,'0'); }
  function startPom(){ if(pomRunning) return; pomRunning=true; pomInterval=setInterval(()=>{ if(pomSeconds>0) pomSeconds--; else { clearInterval(pomInterval); pomRunning=false; pomSeconds=1500; grantXP(20); toast('Pomodoro concluído +20 XP'); } updatePomDisplay(); }, 1000); }
  function stopPom(){ clearInterval(pomInterval); pomRunning=false; pomSeconds=1500; updatePomDisplay(); }
  function skipPom(){ clearInterval(pomInterval); pomRunning=false; pomSeconds=1500; updatePomDisplay(); }

  // Render entry points
  function openView(name){
    $$('[id^="dashboard"], [id^="notas"], [id^="ideias"], [id^="criador"], [id^="programacao"], [id^="estudos"], [id^="produtividade"], [id^="ferramentas"], [id^="config"]').forEach(x=>x.style.display='none');
    const el = $('#'+name);
    if(el) el.style.display='block';
  }

  // Bind events AFTER UI is present
  function bindEvents(){
    // nav
    $$('#nav button').forEach(b=> b.addEventListener('click', ()=>{ $$('#nav button').forEach(x=>x.classList.remove('active')); b.classList.add('active'); openView(b.dataset.view); }));

    // global search => notes
    $('#globalSearch').addEventListener('input', (e)=>{ const q = e.target.value.toLowerCase(); openView('notas'); $('#noteSearch').value = q; renderNotes(); });

    // minimize / tray / close / compact
    $('#minimizeBtn').addEventListener('click', minimizeApp);
    $('#trayIcon').addEventListener('click', restoreApp);
    $('#closeBtn').addEventListener('click', ()=>{ if(confirm('Fechar aplicativo?')) window.close(); });
    $('#maximizeBtn').addEventListener('click', ()=> $('#shell').classList.toggle('compact'));

    // lock
    $('#lockBtn').addEventListener('click', ()=> doLock());
    $('#overlay').addEventListener('click', (e)=>{ if(e.target.id==='overlay'){} });

    // overlay buttons
    $('#loginBtn').addEventListener('click', async ()=> { const pw = $('#passwordInput').value; await doUnlock(pw); });
    $('#setupBtn').addEventListener('click', async ()=> { const pw = $('#passwordInput').value; if(!pw) return toast('Senha vazia'); await createPassword(pw); hideOverlay(); APP = await loadAppData(); renderAll(); });
    $('#resetProtected').addEventListener('click', resetProtection);

    // notes
    $('#noteSearch').addEventListener('input', renderNotes);
    $('#createNote').addEventListener('click', createNote);
    $('#newNoteQuick').addEventListener('click', ()=>{ openView('notas'); createNote(); });
    $('#notesList').addEventListener('click', (e)=>{ const btn = e.target.closest('button'); if(btn && btn.dataset.act==='open'){ openNoteById(btn.dataset.id); }});
    $('#saveNote').addEventListener('click', saveNoteFromEditor);
    $('#deleteNote').addEventListener('click', ()=> deleteNoteById($('#deleteNote').dataset.id || ''));
    // autosave typing
    let autosaveTimer=null;
    $('#noteContent').addEventListener('input', ()=>{ clearTimeout(autosaveTimer); autosaveTimer = setTimeout(()=> saveNoteFromEditor(), 900); });

    // ideas
    $('#addIdea').addEventListener('click', addIdea);

    // projects
    $('#addProject').addEventListener('click', addProject);

    // tasks
    $('#taskText').addEventListener('keypress', (e)=>{ if(e.key==='Enter') addTask(); });
    $('#tasksList').addEventListener('click', (e)=>{ const cb = e.target.closest('input[type="checkbox"]'); if(cb) { const id=cb.dataset.id; const t = APP.tasks.find(x=>x.id===id); if(t){ t.done = cb.checked; saveAppData(APP); renderTasks(); if(cb.checked) { grantXP(10); toast('+10 XP'); } } } const btn = e.target.closest('button'); if(btn && btn.dataset.act==='rm'){ APP.tasks = APP.tasks.filter(t=>t.id!==btn.dataset.id); saveAppData(APP); renderTasks(); } });

    // tools
    $('#calcRun').addEventListener('click', runCalc);
    $('#genPass').addEventListener('click', ()=> genPassword($('#passLength').value));

    // quick shortcuts
    $('#openNotes').addEventListener('click', ()=> { document.querySelector('[data-view="notas"]').click(); });
    $('#openIdeas').addEventListener('click', ()=> { document.querySelector('[data-view="ideias"]').click(); });

    // password config
    $('#setPassword').addEventListener('click', ()=> { showOverlay('Crie sua nova senha', true); });
    $('#removePassword').addEventListener('click', ()=> { if(!localStorage.getItem(KEY_PROTECTED)) return toast('Nenhuma senha configurada'); if(confirm('Remover senha? Isso pode expor dados não encriptados.')) resetProtection(); });

    // save settings
    $('#autoLockMins').addEventListener('change', ()=> { SETTINGS.autoLockMins = +$('#autoLockMins').value; localStorage.setItem(KEY_SETTINGS, JSON.stringify(SETTINGS)); startAutoLockTimer(); });

    // sound toggle
    $('#soundToggle').addEventListener('click', ()=> { SETTINGS.sound = !SETTINGS.sound; localStorage.setItem(KEY_SETTINGS, JSON.stringify(SETTINGS)); toast('Som ' + (SETTINGS.sound ? 'ativado' : 'desativado')); });

    // plan save
    $('#savePlan').addEventListener('click', ()=> { APP.plans.video = $('#planVideo').value; saveAppData(APP); toast('Plano salvo'); });

    // Pomodoro buttons
    $('#pomStart').addEventListener('click', startPom);
    $('#pomStop').addEventListener('click', stopPom);
    $('#pomSkip').addEventListener('click', skipPom);

    // note list open (delegation)
    $('#notesList').addEventListener('click', (e)=> {
      const openBtn = e.target.closest('button[data-act="open"]');
      if(openBtn) openNoteById(openBtn.dataset.id);
    });

    // tasksList render initially
    renderTasks();

    // attach delete/save note dataset guard (ensure elements exist)
    if(!$('#saveNote')) {
      console.warn('saveNote element missing');
    }

    // global activity detection
    ['mousemove','keydown','mousedown','touchstart'].forEach(ev => window.addEventListener(ev, resetInactivity));
  }

  /* Start app */
  document.addEventListener('DOMContentLoaded', ()=> {
    // prepare overlay buttons visibility
    const prot = localStorage.getItem(KEY_PROTECTED);
    if(!prot){ $('#setupBtn').style.display='none'; $('#loginBtn').style.display='inline-block'; }
    // kick splash -> init
    startSplashThenInit();
  });

  // Expose for debugging
  window.WDH = { loadAppData, saveAppData, APP, createPassword, verifyPassword };
})();
</script>
