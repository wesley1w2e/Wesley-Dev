                <div class="notes-list panel" id="notesList" style="margin-top:8px"></div>
              </aside>
              <section style="flex:1">
                <div id="noteEditor" class="panel" style="display:flex;flex-direction:column;gap:8px">
                  <input id="noteTitle" placeholder="Título" />
                  <textarea id="noteContent" class="editor-area" placeholder="Escreva..." style="min-height:220px"></textarea>
