          <button data-view="notas">Bloco de Notas</button>
          <button data-view="ideias">Banco de Ideias</button>
          <button data-view="criador">Criador de Conteúdo</button>
          <button data-view="programacao">Programação</button>
          <button data-view="estudos">Estudos</button>
          <button data-view="produtividade">Produtividade</button>
          <button data-view="ferramentas">Ferramentas</button>
          <button data-view="config">Configurações</button>
        </nav>

        <div style="margin-top:auto">
          <div style="display:flex;gap:8px;align-items:center;justify-content:space-between">
            <div class="muted">Usuário</div>
            <div style="display:flex;gap:8px;align-items:center">
              <div class="pill" id="xpBadge" style="padding:6px 10px;border-radius:999px;background:rgba(255,255,255,0.02)">XP: 0</div>
              <button id="lockBtn" class="wbtn" title="Bloquear">🔒</button>
            </div>
